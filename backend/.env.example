# Which AI provider to use: "anthropic" | "openai" | "gemini" | "mock"
# "mock" runs a deterministic fake extractor with no API calls or cost —
# useful for testing the pipeline (batching, retries, skip logic) for free.
AI_PROVIDER=gemini

# Required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required if AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Required if AI_PROVIDER=gemini — free, no credit card, get a key at
# https://aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here
# "gemini-flash-latest" auto-points to Google's current stable Flash model
# (currently Gemini 3.5 Flash as of July 2026) so this won't go stale again
# when Google deprecates a specific version. Pin to a specific version
# (e.g. "gemini-3.5-flash") only if you need reproducible behavior.
GEMINI_MODEL=gemini-flash-lite-latest

PORT=5000

# Allowed origin for CORS (your frontend URL)
FRONTEND_ORIGIN=http://localhost:3000

# How many CSV rows are sent to the AI per request. Lower = safer against
# response truncation on models with small output budgets, but more API calls.
AI_BATCH_SIZE=15

# Max rows accepted per upload (guards against runaway cost/time)
MAX_ROWS_PER_IMPORT=5000

# Retry attempts per batch before giving up and marking it failed
AI_MAX_RETRIES=3
