# Which AI provider to use: "anthropic" | "openai" | "mock"
# "mock" runs a deterministic fake extractor with no API calls or cost —
# useful for testing the pipeline (batching, retries, skip logic) for free.
AI_PROVIDER=mock

# Required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required if AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

PORT=5000

# Allowed origin for CORS (your frontend URL)
FRONTEND_ORIGIN=http://localhost:3000

# How many CSV rows are sent to the AI per request
AI_BATCH_SIZE=25

# Max rows accepted per upload (guards against runaway cost/time)
MAX_ROWS_PER_IMPORT=5000

# Retry attempts per batch before giving up and marking it failed
AI_MAX_RETRIES=3
